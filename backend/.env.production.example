# Production Environment Variables for Render
# Copy these to Render dashboard and fill in values

NODE_ENV=production
PORT=10000

# JWT Secret - Generate a strong random string
JWT_SECRET=

# Database - Set automatically by Render from PostgreSQL connection
DATABASE_URL=

# Email Configuration
EMAIL_USER=
EMAIL_PASS=

# API Configuration
VITE_API_URL=https://lmcp-backend.onrender.com

# Feature Flags
AI_PREDICTION_ENABLED=true
GAMIFICATION_ENABLED=true
TWO_FACTOR_AUTH_ENABLED=true
