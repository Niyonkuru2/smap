# ===========================================
# Smart Market Price Monitoring System - Backend Configuration
# INSTRUCTIONS: Copy this file to .env and fill in your actual values
# ===========================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=market_prices
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
JWT_SECRET=your_jwt_secret_key_here_minimum_64_characters
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_16character_app_password
FRONTEND_URL=http://localhost:5173
